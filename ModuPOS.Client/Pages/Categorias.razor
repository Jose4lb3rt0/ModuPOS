@using ModuPOS.Client.Services.Categoria
@using ModuPOS.Shared.Enums
@using ModuPOS.Shared.DTOs.Categoria
@using ModuPOS.Shared.DTOs.Producto
@using ModuPOS.Shared.DTOs.Imagen
@using ModuPOS.Client.Services

@page "/categorias"
@attribute [Authorize]
@inject ICategoriaClientService CategoriaService
@inject IJSRuntime JS
<PageTitle>Categorías</PageTitle>

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Categorías</h2>
        <button class="btn btn-primary" @onclick="AbrirModalCrear">
            + Nueva Categoría
        </button>
    </div>

    @if (mensajeError is not null)
    {
        <div class="alert alert-danger alert-dismissible">
            @mensajeError
            <button class="btn-close" @onclick="() => mensajeError = null"></button>
        </div>
    }

    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (categorias.Count == 0)
    {
        <div class="alert alert-info">No hay categorías registradas.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var cat in categorias)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm">
                        @* Banda de color en el borde superior *@
                        <div style="height:5px;background:@cat.Color;border-radius:4px 4px 0 0"></div>

                        @* Imagen *@
                        <div class="text-center pt-3">
                            @if (cat.Imagen?.Url is not null)
                            {
                                <img src="@cat.Imagen.Url" alt="@cat.Nombre"
                                     class="rounded-circle"
                                     style="width:64px;height:64px;object-fit:cover" />
                            }
                            else
                            {
                                <div class="rounded-circle d-inline-flex align-items-center
                                    justify-content-center bg-light"
                                     style="width:64px;height:64px;font-size:28px">
                                    &#128193;
                                </div>
                            }
                        </div>

                        <div class="card-body">
                            <h6 class="card-title mb-0">@cat.Nombre</h6>
                            @if (cat.CategoriaPadreNombre is not null)
                            {
                                <small class="text-muted">Subcategoría de: @cat.CategoriaPadreNombre</small>
                            }
                            <p class="card-text text-muted small mt-1 mb-2">
                                @(string.IsNullOrWhiteSpace(cat.Descripcion)
                                    ? "Sin descripción."
                                    : cat.Descripcion)
                            </p>

                            @* Subcategorías *@
                            @if (cat.Subcategorias.Any())
                            {
                                <div class="mb-2">
                                    @foreach (var sub in cat.Subcategorias)
                                    {
                                        <span class="badge me-1 mb-1"
                                              style="background-color:@sub.Color;color:#333">
                                            @sub.Nombre
                                        </span>
                                    }
                                </div>
                            }

                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <small class="text-muted">
                                    @cat.TotalProductos producto(s)
                                </small>
                                <div>
                                    <button class="btn btn-sm btn-outline-primary me-1"
                                            @onclick="() => AbrirModalEditar(cat)">
                                        Editar
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => ConfirmarEliminar(cat)">
                                        Eliminar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (totalPaginas > 1)
            {
                <nav>
                    <ul class="pagination pagination-sm justify-content-end mt-2">
                        <li class="page-item @(paginaActual == 0 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => IrPagina(paginaActual - 1)">
                                ‹
                            </button>
                        </li>
                        @for (int i = 0; i < totalPaginas; i++)
                        {
                            var p = i;
                            <li class="page-item @(p == paginaActual ? "active" : "")">
                                <button class="page-link" @onclick="() => IrPagina(p)">@(p + 1)</button>
                            </li>
                        }
                        <li class="page-item @(paginaActual >= totalPaginas - 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => IrPagina(paginaActual + 1)">
                                ›
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    }
</div>

@* Modal *@
@if (mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(modoEdicion ? "Editar Categoría" : "Nueva Categoría")
                    </h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    @if (errorModal is not null)
                    {
                        <div class="alert alert-danger">@errorModal</div>
                    }

                    <div class="row g-3">
                        @* Columna izquierda *@
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">Nombre</label>
                                <input class="form-control" @bind="formNombre"
                                       placeholder="Ej: Bebidas calientes" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Descripción</label>
                                <textarea class="form-control" rows="2"
                                          @bind="formDescripcion"
                                          placeholder="Descripción opcional"></textarea>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label">Color</label>
                                    <div class="d-flex gap-2 align-items-center">
                                        @* input type="color" abre el color picker nativo *@
                                        <input type="color" class="form-control form-control-color"
                                               @bind="formColor" style="width:50px;height:38px" />
                                        <input class="form-control form-control-sm font-monospace"
                                               @bind="formColor" maxlength="7" placeholder="#FFFFFF" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Categoría padre</label>
                                    <select class="form-select" @bind="formCategoriaPadreId">
                                        <option value="">— Ninguna (raíz) —</option>
                                        @foreach (var cat in categorias.Where(c => c.Id != categoriaEditandoId))
                                        {
                                            <option value="@cat.Id">@cat.Nombre</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Popup informativo</label>
                                <textarea class="form-control" rows="2"
                                          @bind="formPopup"
                                          placeholder="Texto que aparece al consultar la categoría"></textarea>
                            </div>

                            @* Mayoreo *@
                            <div class="card bg-light p-3">
                                <label class="form-label fw-semibold mb-2">Precios de mayoreo</label>
                                <div class="mb-2">
                                    <label class="form-label small">Tipo</label>
                                    <select class="form-select form-select-sm"
                                            @bind="formTipoMayoreo">
                                        @foreach (var tipo in Enum.GetValues<TipoMayoreo>())
                                        {
                                            <option value="@tipo">@tipo</option>
                                        }
                                    </select>
                                </div>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label small">Mayoreo 1</label>
                                        <input type="number" step="0.01" class="form-control form-control-sm"
                                               @bind="formMayoreo1" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small">Mayoreo 2</label>
                                        <input type="number" step="0.01" class="form-control form-control-sm"
                                               @bind="formMayoreo2" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Columna derecha — imagen *@
                        <div class="col-md-4">
                            <label class="form-label">Imagen</label>
                            <div class="border rounded d-flex align-items-center
                                justify-content-center mb-2"
                                 style="height:160px;background:#f8f9fa;overflow:hidden">
                                @if (previewUrl is not null)
                                {
                                    <img src="@previewUrl" alt="preview"
                                         style="max-height:100%;max-width:100%;object-fit:contain" />
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:40px">&#128193;</span>
                                }
                            </div>
                            <InputFile OnChange="SeleccionarImagen"
                                       accept="image/*"
                                       class="form-control form-control-sm mb-1" />
                            @if (previewUrl is not null)
                            {
                                <button class="btn btn-sm btn-outline-danger w-100"
                                        @onclick="QuitarImagen">
                                    Quitar imagen
                                </button>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal"
                            disabled="@guardando">
                        Cancelar
                    </button>
                    <button class="btn btn-primary" @onclick="GuardarCategoria"
                            disabled="@guardando">
                        @(guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    private List<CategoriaResponse> categorias = new();
    private string? mensajeError;
    private bool cargando = true;

    private bool mostrarModal;
    private bool modoEdicion;
    private bool guardando;
    private string? errorModal;
    private int categoriaEditandoId;

    //Campos del formulario
    private string formNombre = string.Empty;
    private string formDescripcion = string.Empty;
    private string formColor = "#FFFFFF";
    private string? formPopup;
    private int? formCategoriaPadreId;
    private decimal formMayoreo1;
    private decimal formMayoreo2;
    private TipoMayoreo formTipoMayoreo = TipoMayoreo.PrecioFijo;

    //Imagen
    private IBrowserFile? imagenSeleccionada;
    private string? previewUrl;
    private bool quitarImagenFlag;

    //para mis requests
    private int paginaActual = 0;
    private int tamañoPagina = 20;
    private int totalItems = 0;
    private int totalPaginas = 0;

    protected override async Task OnInitializedAsync() => await CargarCategorias();

    private async Task CargarCategorias()
    {
        cargando = true;
        mensajeError = null;
        try { 
            var resultado = await CategoriaService.ObtenerTodasAsync(paginaActual, tamañoPagina);
            categorias = resultado.Items;
            totalItems = resultado.TotalItems;
            totalPaginas = resultado.TotalPages;
        }
        catch (HttpRequestException ex) { mensajeError = ex.Message; }
        finally { cargando = false; }
    }

    //Imagen
    private async Task SeleccionarImagen(InputFileChangeEventArgs e)
    {
        imagenSeleccionada = e.File;
        quitarImagenFlag = false;
        using var stream = imagenSeleccionada.OpenReadStream(5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        previewUrl = $"data:{imagenSeleccionada.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private void QuitarImagen()
    {
        imagenSeleccionada = null;
        previewUrl = null;
        quitarImagenFlag = true;
    }

    //Modal
    private void AbrirModalCrear()
    {
        modoEdicion = false;
        errorModal = null;
        formNombre = string.Empty;
        formDescripcion = string.Empty;
        formColor = "#FFFFFF";
        formPopup = null;
        formCategoriaPadreId = null;
        formMayoreo1 = 0;
        formMayoreo2 = 0;
        formTipoMayoreo = TipoMayoreo.PrecioFijo;
        imagenSeleccionada = null;
        previewUrl = null;
        quitarImagenFlag = false;
        mostrarModal = true;
    }

    private void AbrirModalEditar(CategoriaResponse c)
    {
        modoEdicion = true;
        errorModal = null;
        categoriaEditandoId = c.Id;
        formNombre = c.Nombre;
        formDescripcion = c.Descripcion;
        formColor = c.Color;
        formPopup = c.PopupInformacion;
        formCategoriaPadreId = c.CategoriaPadreId;
        formMayoreo1 = c.Mayoreo1;
        formMayoreo2 = c.Mayoreo2;
        formTipoMayoreo = c.TipoPrecioMayoreo;
        imagenSeleccionada = null;
        previewUrl = c.Imagen?.Url;
        quitarImagenFlag = false;
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        errorModal = null;
    }

    private async Task GuardarCategoria()
    {
        if (string.IsNullOrWhiteSpace(formNombre))
        {
            errorModal = "El nombre es obligatorio.";
            return;
        }

        guardando = true;
        errorModal = null;
        try
        {
            if (modoEdicion)
            {
                var req = new ActualizarCategoriaRequest
                {
                    Id = categoriaEditandoId,
                    Nombre = formNombre,
                    Descripcion = formDescripcion,
                    Color = formColor,
                    PopupInformacion = formPopup,
                    CategoriaPadreId = formCategoriaPadreId,
                    Mayoreo1 = formMayoreo1,
                    Mayoreo2 = formMayoreo2,
                    TipoPrecioMayoreo = formTipoMayoreo,
                    QuitarImagen = quitarImagenFlag
                };
                await CategoriaService.ActualizarAsync(req, imagenSeleccionada);
            }
            else
            {
                var req = new CrearCategoriaRequest
                {
                    Nombre = formNombre,
                    Descripcion = formDescripcion,
                    Color = formColor,
                    PopupInformacion = formPopup,
                    CategoriaPadreId = formCategoriaPadreId,
                    Mayoreo1 = formMayoreo1,
                    Mayoreo2 = formMayoreo2,
                    TipoPrecioMayoreo = formTipoMayoreo
                };
                await CategoriaService.CrearAsync(req, imagenSeleccionada);
            }
            CerrarModal();
            await CargarCategorias();
        }
        catch (HttpRequestException ex) { errorModal = ex.Message; }
        catch (InvalidOperationException ex) { errorModal = ex.Message; }
        finally { guardando = false; }
    }

    private async Task ConfirmarEliminar(CategoriaResponse cat)
    {
        var msg = cat.Subcategorias.Any()
            ? $"'{cat.Nombre}' tiene {cat.Subcategorias.Count} subcategoría(s). ¿Continuar de todas formas?"
            : $"¿Eliminar \"{cat.Nombre}\"?";

        if (!await JS.InvokeAsync<bool>("confirm", msg)) return;

        try
        {
            var ok = await CategoriaService.EliminarAsync(cat.Id);
            if (!ok) mensajeError = "Categoría no encontrada.";
            else await CargarCategorias();
        }
        catch (HttpRequestException ex) { mensajeError = ex.Message; }
    }

    private async Task IrPagina(int pagina)
    {
        paginaActual = pagina;
        await CargarCategorias();
    }
}