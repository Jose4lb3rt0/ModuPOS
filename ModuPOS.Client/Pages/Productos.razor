@using ModuPOS.Client.Services.Producto
@using ModuPOS.Client.Services.Categoria
@using ModuPOS.Shared.DTOs.Producto
@using ModuPOS.Shared.DTOs.Categoria

@page "/productos"
@attribute [Authorize]
@inject IProductoClientService ProductoService
@inject ICategoriaClientService CategoriaService
@inject IJSRuntime JS

<PageTitle>Catálogo de Productos</PageTitle>

<div class="container-fluid py-4">

    @* Cabecera *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Catálogo de Productos</h2>
        <button class="btn btn-primary" @onclick="AbrirModalCrear">
            + Nuevo Producto
        </button>
    </div>

    @* Alerta *@
    @if (mensajeError is not null)
    {
        <div class="alert alert-danger alert-dismissible">
            @mensajeError
            <button class="btn-close" @onclick="() => mensajeError = null"></button>
        </div>
    }

    @* Búsqueda *@
    <div class="row mb-3">
        <div class="col-md-5">
            <div class="input-group">
                <input class="form-control" placeholder="Buscar por nombre o SKU..."
                       @bind="terminoBusqueda" @bind:event="oninput"
                       @onkeyup="ManejarTeclaBusqueda" />
                <button class="btn btn-outline-secondary" @onclick="EjecutarBusqueda">Buscar</button>
                @if (!string.IsNullOrWhiteSpace(terminoBusqueda))
                {
                    <button class="btn btn-outline-danger" @onclick="LimpiarBusqueda">✕</button>
                }
            </div>
        </div>
    </div>

    @* Tabla *@
    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (productos.Count == 0)
    {
        <div class="alert alert-info">
            @(string.IsNullOrWhiteSpace(terminoBusqueda)
                ? "No hay productos registrados."
                : $"Sin resultados para \"{terminoBusqueda}\".")
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width:60px"></th>
                        <th>SKU</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th class="text-end">Precio</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in productos)
                    {
                        <tr>
                            <td>
                                @if (p.Imagen?.Url is not null)
                                {
                                    <img src="@p.Imagen.Url" alt="@p.Nombre"
                                         class="rounded" style="width:44px;height:44px;object-fit:cover" />
                                }
                                else
                                {
                                    <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                         style="width:44px;height:44px;color:#aaa;font-size:20px">
                                        &#128247;
                                    </div>
                                }
                            </td>
                            <td><code>@p.SKU</code></td>
                            <td>@p.Nombre</td>
                            <td>
                                @if (p.Categoria is not null)
                                {
                                    <span class="badge"
                                          style="background-color:@p.Categoria.Color;color:#333">
                                        @p.Categoria.Nombre
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="text-end">@p.PrecioActual.ToString("C")</td>
                            <td class="text-center">
                                <span class="badge @(p.Stock > 0 ? "bg-success" : "bg-danger")">
                                    @p.Stock
                                </span>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => AbrirModalEditar(p)">
                                    Editar
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => ConfirmarEliminar(p)">
                                    Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (totalPaginas > 1)
            {
                <nav>
                    <ul class="pagination pagination-sm justify-content-end mt-2">
                        <li class="page-item @(paginaActual == 0 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => IrPagina(paginaActual - 1)">
                                ‹
                            </button>
                        </li>
                        @for (int i = 0; i < totalPaginas; i++)
                        {
                            var p = i;
                            <li class="page-item @(p == paginaActual ? "active" : "")">
                                <button class="page-link" @onclick="() => IrPagina(p)">@(p + 1)</button>
                            </li>
                        }
                        <li class="page-item @(paginaActual >= totalPaginas - 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => IrPagina(paginaActual + 1)">
                                ›
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        </div>
        <p class="text-muted small">@productos.Count producto(s) encontrado(s).</p>
    }
</div>

@* Modal *@
@if (mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(modoEdicion ? "Editar Producto" : "Nuevo Producto")
                    </h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    @if (errorModal is not null)
                    {
                        <div class="alert alert-danger">@errorModal</div>
                    }

                    <div class="row g-3">
                        @* Columna izquierda *@
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">SKU</label>
                                <input class="form-control" @bind="formSKU"
                                       disabled="@modoEdicion" placeholder="Ej: CAFE-001" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Nombre</label>
                                <input class="form-control" @bind="formNombre"
                                       placeholder="Nombre del producto" />
                            </div>
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label">Precio</label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input type="number" step="0.01" min="0"
                                               class="form-control" @bind="formPrecio" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Stock</label>
                                    <input type="number" min="0" class="form-control"
                                           @bind="formStock" disabled="@modoEdicion" />
                                    @if (modoEdicion)
                                    {
                                        <div class="form-text">Ajusta desde inventario.</div>
                                    }
                                </div>
                            </div>
                            <div class="mb-3 mt-2">
                                <label class="form-label">Categoría</label>
                                <select class="form-select" @bind="formCategoriaId">
                                    <option value="">— Sin categoría —</option>
                                    @foreach (var cat in categorias)
                                    {
                                        <option value="@cat.Id">@cat.Nombre</option>
                                    }
                                </select>
                            </div>
                        </div>

                        @* Columna derecha — imagen *@
                        <div class="col-md-4">
                            <label class="form-label">Imagen</label>
                            @* Preview: muestra imagen existente o la recién seleccionada *@
                            <div class="border rounded d-flex align-items-center justify-content-center mb-2"
                                 style="height:160px;background:#f8f9fa;overflow:hidden">
                                @if (previewUrl is not null)
                                {
                                    <img src="@previewUrl" alt="preview"
                                         style="max-height:100%;max-width:100%;object-fit:contain" />
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:40px">&#128247;</span>
                                }
                            </div>
                            <InputFile OnChange="SeleccionarImagen"
                                       accept="image/*"
                                       class="form-control form-control-sm mb-1" />
                            @if (previewUrl is not null)
                            {
                                <button class="btn btn-sm btn-outline-danger w-100"
                                        @onclick="QuitarImagen">
                                    Quitar imagen
                                </button>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal"
                            disabled="@guardando">
                        Cancelar
                    </button>
                    <button class="btn btn-primary" @onclick="GuardarProducto"
                            disabled="@guardando">
                        @(guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    //Estado de la página
    private List<ProductoResponse> productos = new();
    private List<CategoriaResumenResponse> categorias = new();
    private string? mensajeError;
    private bool cargando = true;
    private string terminoBusqueda = string.Empty;

    //Estado del modal
    private bool mostrarModal;
    private bool modoEdicion;
    private bool guardando;
    private string? errorModal;
    private int productoEditandoId;

    //Campos del formulario
    private string formSKU = string.Empty;
    private string formNombre = string.Empty;
    private decimal formPrecio;
    private int formStock;
    private int? formCategoriaId;

    //Imagen
    private IBrowserFile? imagenSeleccionada;
    private string? previewUrl;
    private bool quitarImagenFlag;

    //para mis requests
    private int paginaActual = 0;
    private int tamañoPagina = 20;
    private int totalItems = 0;
    private int totalPaginas = 0;

    //Ciclo de vida
    protected override async Task OnInitializedAsync()
    {
        //Carga paralela
        var tareas = new[]
        {
            CargarProductos(),
            CargarCategorias()
        };
        await Task.WhenAll(tareas);
    }

    //Carga de datos
    private async Task CargarProductos()
    {
        cargando = true;
        mensajeError = null;

        try {
            var resultado = await ProductoService.ObtenerTodosAsync(paginaActual, tamañoPagina);
            productos = resultado.Items;
            totalItems = resultado.TotalItems;
            totalPaginas = resultado.TotalPages;
        }
        catch (HttpRequestException ex) { mensajeError = $"Error al cargar productos: {ex.Message}"; } //La excepción viene del helper LeerRespuestaAsync
        finally { cargando = false; }
    }

    private async Task CargarCategorias()
    {
        cargando = true;
        mensajeError = null;

        try
        {
            var todas = await CategoriaService.ObtenerTodasAsync();
            categorias = todas.Items.Select(c => new CategoriaResumenResponse(c.Id, c.Nombre, c.Color)).ToList();
        }
        catch { }
    }

    //Búsqueda
    private async Task ManejarTeclaBusqueda(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await EjecutarBusqueda();
    }

    private async Task EjecutarBusqueda()
    {
        cargando = true;
        mensajeError = null;

        try
        {
            var resultado = await ProductoService.BuscarAsync(terminoBusqueda, pageIndex: paginaActual, pageSize: tamañoPagina);
            productos = resultado.Items;
            totalItems = resultado.TotalItems;
            totalPaginas = resultado.TotalPages;
        }
        catch (HttpRequestException ex) { mensajeError = $"Error en la búsqueda: {ex.Message}"; }
        finally { cargando = false; }
    }

    private async Task IrPagina(int pagina)
    {
        paginaActual = pagina;
        await CargarProductos();
    }

    private async Task LimpiarBusqueda()
    {
        terminoBusqueda = string.Empty;
        await CargarProductos();
    }

    //Imagen
    private async Task SeleccionarImagen(InputFileChangeEventArgs e)
    {
        imagenSeleccionada = e.File;
        quitarImagenFlag = false;

        using var stream = imagenSeleccionada.OpenReadStream(5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        var base64 = Convert.ToBase64String(ms.ToArray());
        previewUrl = $"data:{imagenSeleccionada.ContentType};base64,{base64}";
    }

    //Quitar imagen
    private void QuitarImagen()
    {
        imagenSeleccionada = null;
        previewUrl = null;
        quitarImagenFlag = true;
    }

    //Modal abrir
    private void AbrirModalCrear()
    {
        modoEdicion = false;
        errorModal = null;
        formSKU = string.Empty;
        formNombre = string.Empty;
        formPrecio = 0;
        formStock = 0;

        formCategoriaId = null;
        imagenSeleccionada = null;
        previewUrl = null;
        quitarImagenFlag = false;

        mostrarModal = true;
    }

    private void AbrirModalEditar(ProductoResponse p)
    {
        modoEdicion = true;
        errorModal = null;
        productoEditandoId = p.Id;
        formSKU = p.SKU;
        formNombre = p.Nombre;
        formPrecio = p.PrecioActual;
        formStock = p.Stock;

        formCategoriaId = p.Categoria?.Id;
        imagenSeleccionada = null;
        previewUrl = p.Imagen?.Url;
        quitarImagenFlag = false;

        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        errorModal = null;
    }

    //Modal guardar
    private async Task GuardarProducto()
    {
        if (string.IsNullOrWhiteSpace(formNombre) || string.IsNullOrWhiteSpace(formSKU) || formPrecio <= 0)
        {
            errorModal = "Nombre, SKU y precio son obligatorios. El precio debe ser mayor a cero.";
            return;
        }

        guardando = true;
        errorModal = null;

        try
        {
            if (modoEdicion)
            {
                var request = new ActualizarProductoRequest
                {
                    Id = productoEditandoId,
                    Nombre = formNombre,
                    PrecioActual = formPrecio,
                    CategoriaId = formCategoriaId,
                    QuitarImagen = quitarImagenFlag
                    //SKU y stock no se editan desde aquí
                };
                await ProductoService.ActualizarAsync(request, imagenSeleccionada);
            }
            else
            {
                var request = new CrearProductoRequest
                {
                    SKU = formSKU,
                    Nombre = formNombre,
                    PrecioActual = formPrecio,
                    Stock = formStock,
                    CategoriaId = formCategoriaId
                };
                await ProductoService.CrearAsync(request, imagenSeleccionada);
            }

            CerrarModal();
            await CargarProductos(); //refresca la tabla
        }
        catch (HttpRequestException ex) { errorModal = ex.Message; } //El mensaje viene del ExceptionMiddleware
        catch (InvalidOperationException ex) { errorModal = ex.Message; } 
        finally { guardando = false; }
    }

    //Eliminar
    private async Task ConfirmarEliminar(ProductoResponse producto)
    {
        var confirmo = await JS.InvokeAsync<bool>("confirm",
            $"¿Eliminar \"{producto.Nombre}\"? Esta acción no se puede deshacer desde aquí.");

        if (!confirmo) return;

        try
        {
            var eliminado = await ProductoService.EliminarAsync(producto.Id);

            if (!eliminado) mensajeError = "El producto no fue encontrado.";
            else await CargarProductos(); //no recarga la pagina
        }
        catch (HttpRequestException ex) { mensajeError = $"Error al eliminar: {ex.Message}"; }
    }
}